<link href="https://fonts.googleapis.com/css2?family=DM+Serif+Display:ital@0;1&family=DM+Mono:wght@400;500&family=Outfit:wght@300;400;500;600&display=swap" rel="stylesheet">
<style>
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

  :root {
    --navy: #0A1628;
    --navy-mid: #112240;
    --blue: #0C447C;
    --accent: #4FC3F7;
    --accent2: #00E5C3;
    --text: #CDD6F4;
    --text-dim: #7A8BA8;
    --white: #E8F0FE;
    --card: rgba(17, 34, 64, 0.8);
    --border: rgba(79, 195, 247, 0.15);
  }

  html { scroll-behavior: smooth; }

  body {
    background: var(--navy);
    color: var(--text);
    font-family: 'Outfit', sans-serif;
    font-weight: 300;
    line-height: 1.7;
    overflow-x: hidden;
  }

  /* Background grid */
  body::before {
    content: '';
    position: fixed;
    inset: 0;
    background-image:
      linear-gradient(rgba(79,195,247,0.03) 1px, transparent 1px),
      linear-gradient(90deg, rgba(79,195,247,0.03) 1px, transparent 1px);
    background-size: 60px 60px;
    pointer-events: none;
    z-index: 0;
  }

  /* Glow orbs */
  .orb {
    position: fixed;
    border-radius: 50%;
    filter: blur(80px);
    pointer-events: none;
    z-index: 0;
  }
  .orb1 { width: 500px; height: 500px; background: rgba(12,68,124,0.4); top: -100px; right: -100px; }
  .orb2 { width: 400px; height: 400px; background: rgba(0,229,195,0.08); bottom: 10%; left: -100px; }

  /* NAV */
  nav {
    position: fixed; top: 0; left: 0; right: 0; z-index: 100;
    display: flex; justify-content: space-between; align-items: center;
    padding: 1.2rem 4rem;
    background: rgba(10,22,40,0.85);
    backdrop-filter: blur(12px);
    border-bottom: 1px solid var(--border);
  }
  .nav-logo {
    font-family: 'DM Mono', monospace;
    font-size: 14px;
    color: var(--accent);
    letter-spacing: 0.1em;
  }
  .nav-links { display: flex; gap: 2rem; }
  .nav-links a {
    font-size: 13px; color: var(--text-dim); text-decoration: none;
    letter-spacing: 0.05em; transition: color 0.2s;
  }
  .nav-links a:hover { color: var(--accent); }

  /* SECTIONS */
  section { position: relative; z-index: 1; }

  /* HERO */
  .hero {
    min-height: 100vh;
    display: flex; align-items: center;
    padding: 8rem 4rem 4rem;
    max-width: 1100px; margin: 0 auto;
  }
  .hero-content { max-width: 680px; }
  .hero-tag {
    font-family: 'DM Mono', monospace;
    font-size: 12px; color: var(--accent2);
    letter-spacing: 0.15em; text-transform: uppercase;
    margin-bottom: 1.5rem;
    display: flex; align-items: center; gap: 10px;
  }
  .hero-tag::before { content: ''; display: block; width: 32px; height: 1px; background: var(--accent2); }
  .hero h1 {
    font-family: 'DM Serif Display', serif;
    font-size: clamp(3rem, 7vw, 5.5rem);
    color: var(--white);
    line-height: 1.05;
    margin-bottom: 1rem;
  }
  .hero h1 em { color: var(--accent); font-style: italic; }
  .hero-sub {
    font-size: 1.1rem; color: var(--text-dim);
    max-width: 480px; margin-bottom: 2.5rem; line-height: 1.8;
  }
  .hero-cta {
    display: inline-flex; align-items: center; gap: 10px;
    padding: 12px 28px;
    border: 1px solid var(--accent);
    color: var(--accent); font-size: 14px;
    text-decoration: none; border-radius: 4px;
    letter-spacing: 0.05em;
    transition: all 0.25s;
  }
  .hero-cta:hover { background: rgba(79,195,247,0.1); transform: translateY(-2px); }
  .hero-stats {
    display: flex; gap: 3rem; margin-top: 4rem;
    padding-top: 2rem; border-top: 1px solid var(--border);
  }
  .stat-num {
    font-family: 'DM Serif Display', serif;
    font-size: 2.2rem; color: var(--white); display: block;
  }
  .stat-label { font-size: 12px; color: var(--text-dim); letter-spacing: 0.05em; }

  /* CONTENT WRAPPER */
  .content { max-width: 1100px; margin: 0 auto; padding: 0 4rem; }

  /* SECTION HEADING */
  .section-head {
    display: flex; align-items: center; gap: 16px;
    margin-bottom: 3rem;
  }
  .section-num {
    font-family: 'DM Mono', monospace;
    font-size: 12px; color: var(--accent); letter-spacing: 0.1em;
  }
  .section-head h2 {
    font-family: 'DM Serif Display', serif;
    font-size: 2rem; color: var(--white);
  }
  .section-head::after {
    content: ''; flex: 1; height: 1px; background: var(--border);
  }

  /* ABOUT */
  .about { padding: 6rem 0; }
  .about-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 4rem; align-items: center; }
  .about-text p { color: var(--text-dim); margin-bottom: 1rem; font-size: 15px; }
  .about-text p strong { color: var(--text); font-weight: 500; }
  .about-card {
    background: var(--card);
    border: 1px solid var(--border);
    border-radius: 12px;
    padding: 2rem;
    backdrop-filter: blur(10px);
  }
  .about-card-row { display: flex; justify-content: space-between; padding: 10px 0; border-bottom: 1px solid var(--border); font-size: 13px; }
  .about-card-row:last-child { border-bottom: none; }
  .about-card-row span:first-child { color: var(--text-dim); }
  .about-card-row span:last-child { color: var(--white); font-weight: 500; }

  /* SKILLS */
  .skills-section { padding: 4rem 0 6rem; }
  .skills-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(200px, 1fr)); gap: 16px; }
  .skill-card {
    background: var(--card);
    border: 1px solid var(--border);
    border-radius: 10px; padding: 1.5rem;
    backdrop-filter: blur(10px);
    transition: border-color 0.25s, transform 0.25s;
  }
  .skill-card:hover { border-color: var(--accent); transform: translateY(-4px); }
  .skill-icon { font-size: 1.5rem; margin-bottom: 10px; }
  .skill-name { font-size: 14px; font-weight: 500; color: var(--white); margin-bottom: 4px; }
  .skill-type { font-size: 12px; color: var(--text-dim); font-family: 'DM Mono', monospace; }

  /* PROJECTS */
  .projects-section { padding: 4rem 0 6rem; }
  .projects-grid { display: grid; gap: 24px; }
  .project-card {
    background: var(--card);
    border: 1px solid var(--border);
    border-radius: 12px; padding: 2rem;
    backdrop-filter: blur(10px);
    display: grid; grid-template-columns: 1fr auto;
    gap: 1rem; align-items: start;
    transition: border-color 0.25s, transform 0.2s;
  }
  .project-card:hover { border-color: rgba(79,195,247,0.4); transform: translateY(-3px); }
  .project-tag {
    font-family: 'DM Mono', monospace;
    font-size: 11px; color: var(--accent2);
    letter-spacing: 0.1em; text-transform: uppercase;
    margin-bottom: 8px;
  }
  .project-name {
    font-family: 'DM Serif Display', serif;
    font-size: 1.3rem; color: var(--white); margin-bottom: 10px;
  }
  .project-desc { font-size: 14px; color: var(--text-dim); line-height: 1.7; }
  .project-chips { display: flex; flex-wrap: wrap; gap: 8px; margin-top: 16px; }
  .chip {
    font-size: 11px; padding: 3px 10px; border-radius: 20px;
    background: rgba(79,195,247,0.08);
    border: 1px solid rgba(79,195,247,0.2);
    color: var(--accent); font-family: 'DM Mono', monospace;
  }
  .project-num {
    font-family: 'DM Serif Display', serif;
    font-size: 3rem; color: rgba(79,195,247,0.08);
    line-height: 1; user-select: none;
  }

  /* CERTIFICATIONS */
  .cert-section { padding: 4rem 0 6rem; }
  .cert-card {
    background: var(--card);
    border: 1px solid var(--border);
    border-radius: 16px; overflow: hidden;
    backdrop-filter: blur(10px);
    max-width: 780px;
  }
  .cert-header {
    padding: 1.5rem 2rem;
    border-bottom: 1px solid var(--border);
    display: flex; align-items: center; gap: 16px;
  }
  .cert-dot { width: 10px; height: 10px; border-radius: 50%; background: var(--accent2); }
  .cert-title { font-size: 14px; color: var(--white); font-weight: 500; }
  .cert-issuer { font-size: 12px; color: var(--text-dim); font-family: 'DM Mono', monospace; }
  .cert-img-wrap { padding: 1.5rem; }
  .cert-img-wrap img { width: 100%; border-radius: 8px; display: block; }
  .cert-meta { padding: 1rem 2rem 1.5rem; display: flex; gap: 2rem; }
  .cert-meta-item span:first-child { font-size: 11px; color: var(--text-dim); display: block; font-family: 'DM Mono', monospace; letter-spacing: 0.05em; }
  .cert-meta-item span:last-child { font-size: 13px; color: var(--white); font-weight: 500; }

  /* CONTACT */
  .contact-section { padding: 4rem 0 8rem; }
  .contact-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 3rem; align-items: center; }
  .contact-text h3 {
    font-family: 'DM Serif Display', serif;
    font-size: 2rem; color: var(--white); margin-bottom: 1rem;
  }
  .contact-text p { color: var(--text-dim); font-size: 15px; }
  .contact-links { display: flex; flex-direction: column; gap: 16px; }
  .contact-link {
    display: flex; align-items: center; gap: 16px;
    padding: 1rem 1.5rem;
    background: var(--card); border: 1px solid var(--border);
    border-radius: 10px; text-decoration: none;
    transition: border-color 0.2s, transform 0.2s;
  }
  .contact-link:hover { border-color: var(--accent); transform: translateX(4px); }
  .contact-link-icon { font-size: 1.2rem; }
  .contact-link-label { font-size: 11px; color: var(--text-dim); font-family: 'DM Mono', monospace; display: block; }
  .contact-link-value { font-size: 14px; color: var(--white); }

  /* FOOTER */
  footer {
    text-align: center; padding: 2rem;
    border-top: 1px solid var(--border);
    font-size: 12px; color: var(--text-dim);
    font-family: 'DM Mono', monospace;
    position: relative; z-index: 1;
  }

  /* ANIMATIONS */
  @keyframes fadeUp {
    from { opacity: 0; transform: translateY(30px); }
    to { opacity: 1; transform: translateY(0); }
  }
  .hero-tag { animation: fadeUp 0.6s ease both; }
  .hero h1 { animation: fadeUp 0.6s 0.1s ease both; }
  .hero-sub { animation: fadeUp 0.6s 0.2s ease both; }
  .hero-cta { animation: fadeUp 0.6s 0.3s ease both; }
  .hero-stats { animation: fadeUp 0.6s 0.4s ease both; }

  @media (max-width: 768px) {
    nav { padding: 1rem 1.5rem; }
    .nav-links { display: none; }
    .hero { padding: 7rem 1.5rem 3rem; }
    .content { padding: 0 1.5rem; }
    .about-grid { grid-template-columns: 1fr; }
    .contact-grid { grid-template-columns: 1fr; }
    .hero-stats { gap: 1.5rem; }
  }
</style>
</head>
